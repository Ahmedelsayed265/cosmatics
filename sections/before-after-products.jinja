<section class="before-after-products s_block" id="{{ sectionId }}" section-id="{{ sectionId }}">
    <div class="container-fluid">
        <div class="section-header text-center">
            <h2 class="section-title">{{ settings.title }}</h2>
        </div>

        <div class="ba-main-grid">
            {# 1. Comparison Part #}
            <div class="ba-comparison-wrapper">
                <div class="ba-comparison">
                    <div class="ba-image-container ba-after">
                        {% if settings.image_after %}
                        <img src="{{ image_url(settings.image_after, w=800, q=100, f='auto') }}" alt="After" class="ba-img">
                        {% endif %}
                        <span class="ba-label after">{{ _('بعد') }}</span>
                    </div>
                    <div class="ba-image-container ba-before">
                        {% if settings.image_before %}
                        <img src="{{ image_url(settings.image_before, w=800, q=100, f='auto') }}" alt="Before" class="ba-img">
                        {% endif %}
                        <span class="ba-label before">{{ _('قبل') }}</span>
                    </div>
                    <div class="ba-handle">
                        <div class="ba-handle-line"></div>
                        <div class="ba-handle-btn">
                            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
                                <path d="m18 8 4 4-4 4M6 8l-4 4 4 4" />
                            </svg>
                        </div>
                        <div class="ba-handle-line"></div>
                    </div>
                    <input type="range" min="0" max="100" value="50" class="ba-slider">
                </div>
                
                {% set main_prod = settings.linked_product %}
                {% if main_prod %}
                <div class="ba-main-product">
                    {% include 'components/product-card.jinja' with {'product': main_prod} %}
                </div>
                {% endif %}
            </div>

            {# 2. Other Products Slider #}
            {% if safeget(settings, 'products', []) | length > 0 %}
            <div class="ba-products-slider-wrap">
                <div class="swiper other-products-slider"
                     data-autoplay="{{ (settings.slider_autoplay | default(false)) | lower }}"
                     data-delay="{{ settings.slider_autoplay_delay | default(3000) }}"
                     data-arrows="{{ (settings.slider_show_arrows | default(false)) | lower }}"
                     data-pagination="{{ (settings.slider_show_pagination | default(false)) | lower }}">
                    <div class="swiper-wrapper">
                        {% for item in settings.products %}
                        {% set p = item.product %}
                        {% if p %}
                        <div class="swiper-slide">
                            {% include 'components/product-card.jinja' with {'product': p} %}
                        </div>
                        {% endif %}
                        {% endfor %}
                    </div>
                    
                    {% if settings.slider_show_pagination | default(false) %}
                    <div class="swiper-pagination custom-swiper-pagination"></div>
                    {% endif %}

                    {% if settings.slider_show_arrows | default(false) %}
                    <div class="swiper-button-prev"></div>
                    <div class="swiper-button-next"></div>
                    {% endif %}
                </div>
            </div>
            {% endif %}
        </div>
    </div>
</section>

<script>
    (function () {
        function initBA() {
            var section = document.querySelector('[section-id="{{ sectionId }}"]');
            if (!section) return;

            var isRTL = document.documentElement.dir === 'rtl';

            // 1. Swiper for Products
            var sliderEl = section.querySelector('.other-products-slider');
            if (sliderEl && window.Swiper) {
                var isAutoplay = sliderEl.getAttribute('data-autoplay') === 'true';
                var autoplayDelay = parseInt(sliderEl.getAttribute('data-delay')) || 3000;
                var isArrows = sliderEl.getAttribute('data-arrows') === 'true';
                var isPagination = sliderEl.getAttribute('data-pagination') === 'true';

                new Swiper(sliderEl, {
                    slidesPerView: 2,
                    spaceBetween: 15,
                    rtl: isRTL,
                    autoplay: isAutoplay ? { delay: autoplayDelay, disableOnInteraction: false } : false,
                    pagination: isPagination ? { 
                        el: sliderEl.querySelector('.swiper-pagination'), 
                        clickable: true 
                    } : false,
                    navigation: isArrows ? {
                        nextEl: sliderEl.querySelector('.swiper-button-next'),
                        prevEl: sliderEl.querySelector('.swiper-button-prev'),
                    } : false,
                    breakpoints: {
                        768: { slidesPerView: 3 },
                        1024: { slidesPerView: 4 }
                    }
                });
            }

            // 2. Comparison Logic
            var comp = section.querySelector('.ba-comparison');
            if (comp) {
                var range = comp.querySelector('.ba-slider');
                var before = comp.querySelector('.ba-before');
                var handle = comp.querySelector('.ba-handle');
                var imgs = comp.querySelectorAll('.ba-img');

                function update() {
                    var val = parseFloat(range.value);
                    var visualPercent = isRTL ? (100 - val) : val;
                    var pWidth = comp.offsetWidth;
                    imgs.forEach(function(i) { i.style.width = pWidth + 'px'; });
                    before.style.width = visualPercent + '%';
                    handle.style.left = visualPercent + '%';
                }
                range.addEventListener('input', update);
                update();
                window.addEventListener('resize', update);
            }
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initBA);
        } else {
            initBA();
        }
    })();
</script>