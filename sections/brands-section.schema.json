{
  "section_id": "uuid",
  "template": "sections/brands-section.jinja",
  "icon": "fa fa-building",
  "name": {
    "ar": "الماركات التجارية",
    "en": "Brands Section"
  },
  "settings": [
    {
      "type": "text",
      "id": "title",
      "label": { "ar": "العنوان", "en": "Title" },
      "default": "الماركات التجارية"
    },
    {
      "type": "text",
      "id": "view_all_label",
      "label": { "ar": "عنوان رابط الكل", "en": "View All Label" },
      "default": "مشاهدة الكل"
    },
    {
      "type": "url",
      "id": "view_all_url",
      "label": { "ar": "رابط الكل", "en": "View All URL" }
    },
    {
      "type": "header",
      "label": { "ar": "إعدادات السلايدر", "en": "Slider Settings" }
    },
    {
      "id": "slider_autoplay",
      "type": "checkbox",
      "label": { "ar": "تشغيل تلقائي", "en": "Autoplay" },
      "default": false
    },
    {
      "id": "slider_autoplay_delay",
      "type": "number",
      "label": { "ar": "سرعة التشغيل التلقائي (بالمللي ثانية)", "en": "Autoplay Delay (ms)" },
      "default": 0
    },
    {
      "id": "slider_show_arrows",
      "type": "checkbox",
      "label": { "ar": "إظهار أسهم التنقل", "en": "Show Navigation Arrows" },
      "default": false
    },
    {
      "id": "slider_show_pagination",
      "type": "checkbox",
      "label": { "ar": "إظهار نقاط الترقيم", "en": "Show Pagination" },
      "default": false
    },
    {
      "type": "list",
      "id": "logos",
      "label": { "ar": "قائمة الشعارات", "en": "Logo List" },
      "settings": [
        {
          "type": "image",
          "id": "image",
          "label": { "ar": "الشعار", "en": "Logo" }
        },
        {
          "type": "url",
          "id": "url",
          "label": { "ar": "الرابط", "en": "URL" }
        }
      ]
    }
  ]
}
