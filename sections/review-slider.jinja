<section class="review-slider-section s_block" id="{{ sectionId }}" section-id="{{ sectionId }}">
    <div class="container-fluid">
        <div class="review-header">
            <h2 class="section-title">{{ settings.title }}</h2>
        </div>
    </div>

    <div class="review-slider-wrapper">
        {# Content Slider (Slide Effect) #}
        <div class="swiper review-content-slider" 
             data-autoplay="{{ (settings.slider_autoplay | default(false)) | lower }}"
             data-delay="{{ settings.slider_autoplay_delay | default(5000) }}"
             data-arrows="{{ (settings.slider_show_arrows | default(false)) | lower }}"
             data-pagination="{{ (settings.slider_show_pagination | default(false)) | lower }}">
            
            <div class="swiper-wrapper">
                {% for review in safeget(settings, 'reviews', []) %}
                <div class="swiper-slide">
                    <div class="review-text-part">
                        <div class="rev-body">
                            <p class="rev-text">"{{ review.review_text }}"</p>
                            <div class="rev-meta">
                                <h4 class="rev-author">{{ review.reviewer_name }}</h4>
                                <div class="rev-stars">
                                    <svg width="18" height="18" viewBox="0 0 24 24" fill="#FFC107">
                                        <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z" />
                                    </svg>
                                    <span class="rev-rating-val">{{ '%.1f' | format(review.stars | default(5)) }}</span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
                {% endfor %}
            </div>

            {# Footer Navigation #}
            <div class="review-slider-footer">
                <div class="rev-nav-wrap">
                    {% if settings.slider_show_arrows | default(false) %}
                    <div class="swiper-button-prev rev-prev">
                        <svg width="8" height="14" viewBox="0 0 8 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M0.750107 0.75C0.750107 0.75 6.75005 5.16893 6.75006 6.75005C6.75007 8.33116 0.75006 12.75 0.75006 12.75"
                                stroke="#666666" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </div>
                    {% endif %}

                    {% if settings.slider_show_pagination | default(false) %}
                    <div class="swiper-pagination-fraction rev-pagination"></div>
                    {% endif %}

                    {% if settings.slider_show_arrows | default(false) %}
                    <div class="swiper-button-next rev-next">
                        <svg width="8" height="14" viewBox="0 0 8 14" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M6.74995 0.75C6.74995 0.75 0.750013 5.16893 0.75 6.75005C0.749987 8.33116 6.75 12.75 6.75 12.75"
                                stroke="#330017" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                    </div>
                    {% endif %}
                </div>
            </div>
        </div>

        {# Visual Slider (Fade Effect) #}
        <div class="swiper review-visual-slider">
            <div class="swiper-wrapper">
                {% for review in safeget(settings, 'reviews', []) %}
                <div class="swiper-slide">
                    <div class="review-visual-content">
                        {% if review.bg_image %}
                        <img src="{{ image_url(review.bg_image, w=900, f='auto') }}" alt="Review Background"
                            class="rev-bg-img">
                        {% endif %}

                        {% set product = review.linked_product %}
                        {% if product %}
                        <div class="rev-product-card-wrap">
                            {% include 'components/product-card.jinja' %}
                        </div>
                        {% endif %}
                    </div>
                </div>
                {% endfor %}
            </div>
        </div>
    </div>
</section>

<script>
    (function () {
        function initReviewSlider() {
            var section = document.querySelector('[section-id="{{ sectionId }}"]');
            if (!section) return;

            var visualEl = section.querySelector('.review-visual-slider');
            var contentEl = section.querySelector('.review-content-slider');
            if (!contentEl) return;

            var isAutoplay = contentEl.getAttribute('data-autoplay') === 'true';
            var autoplayDelay = parseInt(contentEl.getAttribute('data-delay')) || 5000;
            var isPagination = contentEl.getAttribute('data-pagination') === 'true';
            var isArrows = contentEl.getAttribute('data-arrows') === 'true';

            if (window.Swiper) {
                // 1. Image Slider (Fade)
                var visualSwiper = new Swiper(visualEl, {
                    effect: 'fade',
                    fadeEffect: { crossFade: true },
                    allowTouchMove: false,
                    speed: 1000,
                });

                // 2. Text Slider (Slide)
                var contentSwiper = new Swiper(contentEl, {
                    slidesPerView: 1,
                    rtl: true,
                    speed: 800,
                    autoplay: isAutoplay ? { delay: autoplayDelay, disableOnInteraction: false } : false,
                    pagination: isPagination ? {
                        el: contentEl.querySelector('.rev-pagination'),
                        type: 'fraction',
                    } : false,
                    navigation: isArrows ? {
                        nextEl: contentEl.querySelector('.rev-next'),
                        prevEl: contentEl.querySelector('.rev-prev'),
                    } : false
                });

                contentSwiper.controller.control = visualSwiper;
            }
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initReviewSlider);
        } else {
            initReviewSlider();
        }
    })();
</script>