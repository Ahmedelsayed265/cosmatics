{
  "section_id": "uuid",
  "template": "sections/month-brands.jinja",
  "icon": "fa fa-star",
  "name": {
    "ar": "ماركات الشهر",
    "en": "Month Brands"
  },
  "settings": [
    {
      "id": "title",
      "type": "text",
      "label": { "ar": "العنوان", "en": "Title" },
      "default": "ماركات الشهر"
    },
    {
      "id": "view_all_title",
      "type": "text",
      "label": { "ar": "عنوان رابط الكل", "en": "View All Text" },
      "default": "عرض الكل"
    },
    {
      "id": "view_all_url",
      "type": "url",
      "label": { "ar": "رابط الكل", "en": "View All URL" }
    },
    {
      "type": "header",
      "label": { "ar": "إعدادات السلايدر", "en": "Slider Settings" }
    },
    {
      "id": "slider_autoplay",
      "type": "checkbox",
      "label": { "ar": "تشغيل تلقائي", "en": "Autoplay" },
      "default": false
    },
    {
      "id": "slider_autoplay_delay",
      "type": "number",
      "label": { "ar": "سرعة التشغيل التلقائي (بالمللي ثانية)", "en": "Autoplay Delay (ms)" },
      "default": 3000
    },
    {
      "id": "slider_show_arrows",
      "type": "checkbox",
      "label": { "ar": "إظهار أسهم التنقل", "en": "Show Navigation Arrows" },
      "default": false
    },
    {
      "id": "slider_show_pagination",
      "type": "checkbox",
      "label": { "ar": "إظهار نقاط الترقيم", "en": "Show Pagination" },
      "default": false
    },
    {
      "id": "brands",
      "type": "list",
      "label": { "ar": "الماركات", "en": "Brands" },
      "settings": [
        {
          "id": "image",
          "type": "image",
          "label": { "ar": "الصورة", "en": "Image" }
        },
        {
          "id": "name",
          "type": "text",
          "label": { "ar": "الاسم", "en": "Name" }
        },
        {
          "id": "url",
          "type": "url",
          "label": { "ar": "الرابط", "en": "URL" }
        }
      ]
    }
  ]
}
