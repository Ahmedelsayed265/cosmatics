{
  "section_id": "uuid",
  "template": "sections/before-after-products.jinja",
  "icon": "fa fa-columns",
  "name": {
    "ar": "قبل وبعد مع منتج",
    "en": "Before & After with Product"
  },
  "settings": [
    {
      "id": "title",
      "type": "text",
      "label": { "ar": "العنوان", "en": "Title" }
    },
    {
      "type": "header",
      "label": { "ar": "إعدادات السلايدر (للكروت)", "en": "Slider Settings (Cards)" }
    },
    {
      "id": "slider_autoplay",
      "type": "checkbox",
      "label": { "ar": "تشغيل تلقائي", "en": "Autoplay" },
      "default": false
    },
    {
      "id": "slider_autoplay_delay",
      "type": "number",
      "label": { "ar": "سرعة التشغيل التلقائي (بالمللي ثانية)", "en": "Autoplay Delay (ms)" },
      "default": 3000
    },
    {
      "id": "slider_show_arrows",
      "type": "checkbox",
      "label": { "ar": "إظهار أسهم التنقل", "en": "Show Navigation Arrows" },
      "default": false
    },
    {
      "id": "slider_show_pagination",
      "type": "checkbox",
      "label": { "ar": "إظهار نقاط الترقيم", "en": "Show Pagination" },
      "default": false
    },
    {
      "id": "image_before",
      "type": "image",
      "label": { "ar": "الصورة قبل", "en": "Image Before" }
    },
    {
      "id": "image_after",
      "type": "image",
      "label": { "ar": "الصورة بعد", "en": "Image After" }
    },
    {
      "id": "linked_product",
      "type": "product",
      "label": { "ar": "المنتج المرتبط (اختياري)", "en": "Linked Product (Optional)" }
    },
    {
      "id": "products",
      "type": "list",
      "label": { "ar": "قائمة منتجات أخرى", "en": "Other Products List" },
      "settings": [
        {
          "id": "product",
          "type": "product",
          "label": { "ar": "المنتج", "en": "Product" }
        }
      ]
    }
  ]
}
