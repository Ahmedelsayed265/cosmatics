{#
  Product Tabs Section - قسم علامات تبويب المنتجات
#}

{% set _lang = safeget(session, 'lang') or 'ar' %}
{% set tabs_list = safeget(settings, 'tabs', []) %}
{% if tabs_list is none %}{% set tabs_list = [] %}{% endif %}
{% set has_tabs = tabs_list | length > 0 %}

{% set section_title = safeget(settings, 'title') or '' %}
{% set section_subtitle = safeget(settings, 'subtitle') or '' %}
{% set title_align = safeget(settings, 'title_alignment') or 'right' %}
{% set title_color = safeget(settings, 'title_color') or '' %}
{% set subtitle_color = safeget(settings, 'subtitle_color') or '' %}

{% set store_permalink = safeget(store, 'permalink') or '' %}
{% if store_permalink and not store_permalink.endswith('/') %}{% set store_permalink = store_permalink ~ '/' %}{% endif %}

<section id="products-tabs-{{ sectionId }}"
         class="products-tabs-section container-fluid s_block"
         section-id="{{ sectionId }}"
         data-products-tabs
         data-base-url="{{ store_permalink | e }}"
         data-placeholder-img="{{ image_url(('product-img.svg' | asset_url), w=235, q=100, f='auto') | e }}"
         aria-labelledby="products-tabs-heading-{{ sectionId }}"
         style="
           {% if title_color %}--products-tabs-title-color: {{ title_color }};{% endif %}
           {% if subtitle_color %}--products-tabs-subtitle-color: {{ subtitle_color }};{% endif %}
           {% if safeget(settings, 'tab_active_text_color') %}--products-tabs-active-text: {{ settings.tab_active_text_color }};{% endif %}
           {% if safeget(settings, 'tab_active_border_color') %}--products-tabs-active-border: {{ settings.tab_active_border_color }};{% endif %}
           {% if safeget(settings, 'tab_inactive_text_color') %}--products-tabs-inactive-text: {{ settings.tab_inactive_text_color }};{% endif %}
           {% if safeget(settings, 'tab_inactive_border_color') %}--products-tabs-inactive-border: {{ settings.tab_inactive_border_color }};{% endif %}
         "
         data-autoplay="{{ (settings.slider_autoplay | default(false)) | lower }}"
         data-delay="{{ settings.slider_autoplay_delay | default(3000) }}"
         data-arrows="{{ (settings.slider_show_arrows | default(false)) | lower }}"
         data-pagination="{{ (settings.slider_show_pagination | default(false)) | lower }}">
  <div class="products-tabs-container container-fluid">
    <div class="products-tabs-top-row">
      <header class="products-tabs-header products-tabs-header--{{ title_align }}">
        {% if section_title %}
          <h2 id="products-tabs-heading-{{ sectionId }}" class="products-tabs-title">{{ section_title }}</h2>
        {% endif %}
        {% if section_subtitle %}
          <p class="products-tabs-subtitle">{{ section_subtitle }}</p>
        {% endif %}
      </header>
      {% if has_tabs %}
      <nav class="products-tabs-nav" aria-label="{{ _('Product tabs') }}">
        <div class="products-tabs-tabs-wrap" role="tablist" aria-label="{{ _('Select product collection') }}">
          {% for tab in tabs_list %}
            {% set tab_label = safeget(tab, 'tab_title') | default('Tab ' ~ loop.index) %}
            <button type="button"
                    class="products-tabs-tab{% if loop.first %} products-tabs-tab--active{% endif %}"
                    role="tab"
                    id="products-tab-{{ sectionId }}-{{ loop.index0 }}"
                    aria-selected="{{ 'true' if loop.first else 'false' }}"
                    aria-controls="products-tabs-panel-{{ sectionId }}-{{ loop.index0 }}"
                    data-index="{{ loop.index0 }}"
                    tabindex="{{ '0' if loop.first else '-1' }}">
              <span class="products-tabs-tab-label">{{ tab_label }}</span>
            </button>
          {% endfor %}
        </div>
      </nav>
      {% endif %}
    </div>

    {% if has_tabs %}
      <div class="products-tabs-panels">
        {% for tab in tabs_list %}
          {% set tab_products = safeget(tab, 'products', []) %}
          {% if tab_products is mapping %}
            {% set tab_results = safeget(tab_products, 'results', []) %}
          {% else %}
            {% set tab_results = tab_products %}
          {% endif %}
          {% if tab_results is none %}{% set tab_results = [] %}{% endif %}
          
          {% set has_products_server = tab_results and (tab_results | length) > 0 %}

          <div class="products-tabs-panel{% if has_products_server %} has-products{% endif %}"
               role="tabpanel"
               id="products-tabs-panel-{{ sectionId }}-{{ loop.index0 }}"
               aria-labelledby="products-tab-{{ sectionId }}-{{ loop.index0 }}"
               aria-live="polite"
               data-index="{{ loop.index0 }}"
               {% if not loop.first %}hidden{% endif %}>
            <div class="products-tabs-slider-wrap">
              <div class="swiper products-tabs-slider" data-products-tabs-slider>
                <div class="swiper-wrapper">
                  {% if has_products_server %}
                    {% for product in tab_results %}
                      <div class="swiper-slide">
                        {% include 'components/product-card.jinja' %}
                      </div>
                    {% endfor %}
                  {% endif %}
                </div>

                {% if settings.slider_show_pagination | default(false) %}
                <div class="swiper-pagination custom-swiper-pagination"></div>
                {% endif %}

                {% if settings.slider_show_arrows | default(false) %}
                <div class="swiper-button-next"></div>
                <div class="swiper-button-prev"></div>
                {% endif %}
              </div>
            </div>
          </div>
        {% endfor %}
      </div>
    {% endif %}
  </div>
</section>

<link rel="stylesheet" href="{{ 'products-tabs.css' | asset_url }}" />
{% if has_tabs %}
<script src="{{ 'products-tabs.js' | asset_url }}" defer></script>
<script>
(function() {
  window.__productsTabsConfig = window.__productsTabsConfig || {};
  window.__productsTabsConfig['{{ sectionId }}'] = {
    sectionId: '{{ sectionId }}',
    baseUrl: '{{ store_permalink | e }}',
    lang: '{{ _lang }}',
    placeholderImg: '{{ image_url(("product-img.svg" | asset_url), w=235, q=100, f="auto") | e }}',
    nextLabel: {{ _('Next') | tojson }},
    prevLabel: {{ _('Previous') | tojson }}
  };
})();
</script>
{% endif %}
