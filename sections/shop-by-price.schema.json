{
  "section_id": "uuid",
  "template": "sections/shop-by-price.jinja",
  "icon": "fa fa-play",
  "name": {
    "ar": "تسوق حسب السعر",
    "en": "Shop by Price"
  },
  "settings": [
    {
      "id": "title",
      "type": "text",
      "label": { "ar": "العنوان", "en": "Title" }
    },
    {
      "type": "header",
      "label": { "ar": "إعدادات السلايدر", "en": "Slider Settings" }
    },
    {
      "id": "slider_autoplay",
      "type": "checkbox",
      "label": { "ar": "تشغيل تلقائي", "en": "Autoplay" },
      "default": false
    },
    {
      "id": "slider_autoplay_delay",
      "type": "number",
      "label": { "ar": "سرعة التشغيل التلقائي (بالمللي ثانية)", "en": "Autoplay Delay (ms)" },
      "default": 3000
    },
    {
      "id": "slider_show_arrows",
      "type": "checkbox",
      "label": { "ar": "إظهار أسهم التنقل", "en": "Show Navigation Arrows" },
      "default": false
    },
    {
      "id": "slider_show_pagination",
      "type": "checkbox",
      "label": { "ar": "إظهار نقاط الترقيم", "en": "Show Pagination" },
      "default": false
    },
    {
      "id": "prices",
      "type": "list",
      "label": { "ar": "الاسعار", "en": "Prices" },
      "settings": [
        {
          "id": "subtitle",
          "type": "text",
          "label": { "ar": "العنوان الفرعي (مثل: أقل من)", "en": "Subtitle (e.g., Less than)" },
          "default": "أقل من"
        },
        {
          "id": "title",
          "type": "text",
          "label": { "ar": "السعر (مثل: 150 ريال)", "en": "Price (e.g., 150 SAR)" }
        },
        {
          "id": "url",
          "type": "url",
          "label": { "ar": "الرابط", "en": "URL" }
        }
      ]
    }
  ]
}
