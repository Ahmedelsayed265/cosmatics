{
  "section_id": "uuid",
  "template": "sections/image-with-text.jinja",
  "icon": "fa fa-align-left",
  "name": {
    "ar": "صورة مع نص (بعرض كامل)",
    "en": "Image with Text (Full Width)"
  },
  "settings": [
    {
      "id": "image",
      "type": "image",
      "label": { "ar": "الصورة", "en": "Image" }
    },
    {
      "id": "image_position",
      "type": "select",
      "label": { "ar": "موقع الصورة", "en": "Image Position" },
      "options": [
        { "value": "left", "label": { "ar": "يسار", "en": "Left" } },
        { "value": "right", "label": { "ar": "يمين", "en": "Right" } }
      ],
      "default": "right"
    },
    {
      "id": "title",
      "type": "text",
      "label": { "ar": "العنوان", "en": "Title" },
      "default": "العنوان هنا"
    },
    {
      "id": "subtitle",
      "type": "textarea",
      "label": { "ar": "الوصف", "en": "Description" },
      "default": "الوصف يظهر هنا تحت العنوان"
    },
    {
      "id": "btn_text",
      "type": "text",
      "label": { "ar": "نص الزر", "en": "Button Text" },
      "default": "اكتشف المجموعة"
    },
    {
      "id": "btn_url",
      "type": "url",
      "label": { "ar": "رابط الزر", "en": "Button URL" }
    },
    {
      "type": "header",
      "label": { "ar": "الألوان", "en": "Colors" }
    },
    {
      "id": "bg_color",
      "type": "color",
      "label": { "ar": "لون الخلفية", "en": "Background Color" },
      "default": "#ffffff"
    },
    {
      "id": "title_color",
      "type": "color",
      "label": { "ar": "لون العنوان", "en": "Title Color" },
      "default": "#330017"
    },
    {
      "id": "subtitle_color",
      "type": "color",
      "label": { "ar": "لون الوصف", "en": "Description Color" },
      "default": "#666666"
    },
    {
      "id": "btn_color",
      "type": "color",
      "label": { "ar": "لون الزر", "en": "Button Color" },
      "default": "#330017"
    }
  ]
}
