{
  "section_id": "uuid",
  "template": "sections/offers-banners.jinja",
  "icon": "fa fa-tags",
  "name": {
    "ar": "عروض كوبونات",
    "en": "Offers Coupons"
  },
  "settings": [
    {
      "id": "title",
      "type": "text",
      "label": { "ar": "العنوان الرئيسي", "en": "Main Title" },
      "default": "عروض لوازم الجمال"
    },
    {
      "type": "header",
      "label": { "ar": "إعدادات السلايدر", "en": "Slider Settings" }
    },
    {
      "id": "slider_autoplay",
      "type": "checkbox",
      "label": { "ar": "تشغيل تلقائي", "en": "Autoplay" },
      "default": false
    },
    {
      "id": "slider_autoplay_delay",
      "type": "number",
      "label": { "ar": "سرعة التشغيل التلقائي (بالمللي ثانية)", "en": "Autoplay Delay (ms)" },
      "default": 3000
    },
    {
      "id": "slider_show_arrows",
      "type": "checkbox",
      "label": { "ar": "إظهار أسهم التنقل", "en": "Show Navigation Arrows" },
      "default": true
    },
    {
      "id": "slider_show_pagination",
      "type": "checkbox",
      "label": { "ar": "إظهار نقاط الترقيم", "en": "Show Pagination" },
      "default": false
    },
    {
      "id": "items",
      "type": "list",
      "label": { "ar": "العروض", "en": "Offers" },
      "settings": [
        {
          "id": "image",
          "type": "image",
          "label": { "ar": "الصورة", "en": "Image" }
        },
        {
          "id": "title",
          "type": "text",
          "label": { "ar": "عنوان العرض (اختياري)", "en": "Offer Title (Optional)" }
        },
        {
          "id": "url",
          "type": "url",
          "label": { "ar": "الرابط", "en": "URL" }
        }
      ]
    }
  ]
}
