    <ul class="slide-menu-drawer-ul slide-menu-theme-text">
        {% for menu in store.settings.menus.main_menu.items %}
            {% if menu.url %}
            {% if menu.items | length > 0 %}
            <li class="slide-menu-ul-li slide-menu-drawer-li slide-menu-drawer-li--has-sub {% if menu.slug == 'all_categories' %} all-categories {% endif %}">
