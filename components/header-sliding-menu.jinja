<script>
document.addEventListener('DOMContentLoaded', function() {
    function cleanUrl(url) {
        if (url.startsWith("//")) url = "/" + url.slice(2);
        url = url.replace(/([^:]\/)\/+/g, "$1");
        if (url !== '/' && url.endsWith('/')) url = url.slice(0, -1);
        return url;
    }
    var menuLinks = document.querySelectorAll('#sliding-menu .menu-link');
    menuLinks.forEach(function(link) {
        var href = link.getAttribute('href');
        if (href && href !== '#') link.href = cleanUrl(href);
        link.addEventListener('click', function(event) {
            if (this.getAttribute('href') === '#') return;
            event.preventDefault();
        });
    });
    var clickableSpans = document.querySelectorAll('#sliding-menu .clickable-span');
    clickableSpans.forEach(function(span) {
        span.addEventListener('click', function(event) {
            event.stopPropagation();
            var parentAnchor = span.closest('a');
            if (parentAnchor && parentAnchor.getAttribute('href') !== '#') {
                window.location.href = parentAnchor.href;
            }
        });
    });

    /* تسجيل الدخول: إغلاق القائمة أولاً ثم تنفيذ الدخول بعد لحظة حتى لا يمنع الإغلاق التنفيذ */
    var slidingMenu = document.getElementById('sliding-menu');
    if (slidingMenu) {
        slidingMenu.addEventListener('click', function(e) {
            var trigger = e.target.closest('.slide-menu-drawer-login-trigger');
            if (!trigger) return;
            e.preventDefault();
            e.stopPropagation();
            var loginUrl = trigger.getAttribute('href') || '{{ url_for("login_page") }}';
            if (typeof closeSlidingMenu === 'function') closeSlidingMenu();
            setTimeout(function() {
                if (typeof window.handleLoginAction === 'function') {
                    window.handleLoginAction('', false);
                } else {
                    window.location.href = loginUrl;
                }
            }, 280);
        }, true);
    }
});
document.addEventListener('zid-customer-fetched', function (event) {
    var customer = event.detail.customer;
    if (customer && customer.name) {
        var greeting = document.getElementById('customer-greeting-alt');
        if (greeting) {
            var helloWord = greeting.textContent.trim().split(' ')[0];
            greeting.textContent = helloWord + ' ' + customer.name;
        }
        var helloBtn = document.getElementById('hello-btn-alt');
        var loginBtn = document.getElementById('login-btn-alt');
        if (helloBtn) helloBtn.style.display = 'inline-block';
        if (loginBtn) loginBtn.style.display = 'none';
    }
});
</script>
