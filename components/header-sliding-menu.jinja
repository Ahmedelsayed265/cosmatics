                    <summary class="slide-menu-drawer-collapse-summary">
                        <span class="slide-menu-drawer-link-icon slide-menu-drawer-link-img-wrap">
                            {% if safeget(menu, 'image') %}
                            <img src="{{ image_url(safeget(menu, 'image'), w=80, h=80, q=100, f='auto') }}" alt="" class="slide-menu-drawer-cat-img" width="36" height="36">
                            {% else %}
                            <span class="slide-menu-cat-icon slide-menu-cat-icon--{{ loop.index % 9 or 9 }}"></span>
                            {% endif %}
                        </span>
                        <span class="slide-menu-drawer-link-text">{{ menu.label }}</span>
                        <span class="slide-menu-drawer-sub-arrow" aria-hidden="true">

