<script>
    (function () {
        function initFooterLinksCollapse() {
            var collapses = document.querySelectorAll('.js-footer-links-collapse');
            if (!collapses.length) return;

            var isMobile = window.matchMedia('(max-width: 991px)').matches;

            collapses.forEach(function (wrap, index) {
                var toggle = wrap.querySelector('.js-footer-links-toggle');
                var body = wrap.querySelector('.footer-links-collapse-body');
                if (!toggle || !body) return;

                // Desktop: always open, no JS behavior needed
                if (!isMobile) {
                    wrap.classList.add('is-open');
                    return;
                }

                // Mobile: first section open by default, others closed
                if (index === 0) {
                    wrap.classList.add('is-open');
                } else {
                    wrap.classList.remove('is-open');
                }

                toggle.addEventListener('click', function () {
                    // Toggle current collapse only
                    wrap.classList.toggle('is-open');
                });
            });
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', initFooterLinksCollapse);
        } else {
            initFooterLinksCollapse();
        }

        // Re-run on resize to adapt when switching between mobile/desktop
        window.addEventListener('resize', function () {
            initFooterLinksCollapse();
        });
    })();
</script>

