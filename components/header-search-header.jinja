                            </clipPath>
                        </defs>
                    </svg>

                    <span class="header-custom-link-text">{{ settings.custom_link_text }}</span>
                </button>
            </div>
            {% endif %}

            {% if not ('hide_search_bar' in header_options) %}
            <div class="p-2 d-flex align-items-center search-input lg-search-div flex-grow-1 search-header-search-wrap">
                <div class="form-group" style="position: relative; margin: 0px">
                    <span class="icon-search search-input-icon" style="z-index: 1">

                        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                            <path d="M17.5 17.5L22 22" stroke="#8E8E93" stroke-width="1.5" stroke-linecap="round"
                                stroke-linejoin="round" />
                            <path
                                d="M20 11C20 6.02944 15.9706 2 11 2C6.02944 2 2 6.02944 2 11C2 15.9706 6.02944 20 11 20C15.9706 20 20 15.9706 20 11Z"
                                stroke="#8E8E93" stroke-width="1.5" stroke-linejoin="round" />
                        </svg>

                    </span>
                    <div class="autocomplete" style="position: relative">
                        <input type="text" data-cat-id="{{ category.id if category is defined else '' }}"
                            class="form-control search-input-input"
                            placeholder="{% if settings.header_search_placeholder %}{{ settings.header_search_placeholder }}{% else %}{{ _('Search') }}{% endif %}"
                            style="font-size: 16px">
                        <div class="autocomplete-items"></div>
                    </div>
                </div>
            </div>
            {% endif %}

            <div class="d-flex align-items-center header-logo search-header-logo-wrap">
                <a href="/" style="width: auto; height: 100%; display: contents">
                    {% if settings.header_logo %}
                    {% set logoUrl = settings.header_logo %}
                    {% else %}
                    {% set logoUrl = store.logo %}
                    {% endif %}
                    <img class="image-logo" src="{{ image_url(logoUrl, h=175, q=100) }}" alt="{{ store.name }}"
                        style="width: auto; max-height: 100%" decoding="async" fetchpriority="high">
                </a>
            </div>

        </div>
    </div>
</div>

<div id="offers-offcanvas" class="offers-offcanvas" aria-hidden="true">
    <div class="offers-offcanvas-backdrop" data-close-offers-offcanvas></div>
    <div class="offers-offcanvas-panel">
        <button type="button" class="offers-offcanvas-close" data-close-offers-offcanvas aria-label="{{ _('Close') }}">
            <svg width="24" height="24" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
                <path d="M18 6L6 18M6 6L18 18" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                    stroke-linejoin="round" />
            </svg>
        </button>
        <h2 class="offers-offcanvas-title">{{ _('Available offers') }} ({{ offers_list | length }})</h2>
        {% if offers_list | length > 0 %}
        <div class="offers-offcanvas-content">
            {% for item in offers_list %}
            <a href="{{ item.url | default('#') }}" class="offers-offcanvas-card">
                <span class="offers-offcanvas-card-img-wrap">
                    {% if item.image %}
                    <img src="{{ image_url(item.image, w=160, q=90, f='auto') }}" alt="{{ item.title | default('') }}"
                        class="offers-offcanvas-card-img" loading="lazy">
                    {% else %}
                    <span class="offers-offcanvas-card-img-placeholder"></span>
                    {% endif %}
                </span>
                <span class="offers-offcanvas-card-title">{{ item.title | default(_('Offer')) }}</span>
            </a>
            {% endfor %}
        </div>
        {% else %}
        <div class="offers-offcanvas-empty">
            <span class="offers-offcanvas-empty-icon" aria-hidden="true">

                <svg width="150" height="150" viewBox="0 0 150 150" fill="none" xmlns="http://www.w3.org/2000/svg">
                    <path
                        d="M48.0732 122.6C51.7671 122.6 53.6141 122.6 55.2967 123.225C55.5304 123.311 55.7608 123.407 55.9873 123.511C57.6186 124.259 58.9246 125.565 61.5366 128.177C67.5484 134.189 70.5544 137.195 74.253 137.472C74.7503 137.509 75.2497 137.509 75.747 137.472C79.4456 137.195 82.4516 134.189 88.4634 128.177C91.0754 125.565 92.3814 124.259 94.0127 123.511C94.2393 123.407 94.4696 123.311 94.7033 123.225C96.3859 122.6 98.2329 122.6 101.927 122.6H102.608C112.033 122.6 116.745 122.6 119.673 119.673C122.6 116.745 122.6 112.033 122.6 102.608V101.927C122.6 98.2329 122.6 96.3859 123.225 94.7033C123.311 94.4696 123.407 94.2393 123.511 94.0127C124.259 92.3814 125.565 91.0754 128.177 88.4634C134.189 82.4516 137.195 79.4456 137.472 75.747C137.509 75.2497 137.509 74.7503 137.472 74.253C137.195 70.5544 134.189 67.5484 128.177 61.5366C125.565 58.9246 124.259 57.6186 123.511 55.9873C123.407 55.7608 123.311 55.5304 123.225 55.2967C122.6 53.6141 122.6 51.7671 122.6 48.0732V47.3918C122.6 37.9674 122.6 33.2552 119.673 30.3274C116.745 27.3996 112.033 27.3996 102.608 27.3996H101.927C98.2329 27.3996 96.3859 27.3996 94.7033 26.7753C94.4696 26.6886 94.2393 26.5932 94.0127 26.4892C92.3814 25.7409 91.0754 24.4349 88.4634 21.8229C82.4516 15.8111 79.4456 12.8051 75.747 12.528C75.2497 12.4907 74.7503 12.4907 74.253 12.528C70.5544 12.8051 67.5484 15.8111 61.5366 21.8229C58.9246 24.4349 57.6186 25.7409 55.9873 26.4892C55.7608 26.5932 55.5304 26.6886 55.2967 26.7753C53.6141 27.3996 51.7671 27.3996 48.0732 27.3996H47.3918C37.9674 27.3996 33.2552 27.3996 30.3274 30.3274C27.3996 33.2552 27.3996 37.9674 27.3996 47.3918V48.0732C27.3996 51.7671 27.3996 53.6141 26.7753 55.2967C26.6886 55.5304 26.5932 55.7608 26.4892 55.9873C25.7409 57.6186 24.4349 58.9246 21.8229 61.5366C15.8111 67.5484 12.8051 70.5544 12.528 74.253C12.4907 74.7503 12.4907 75.2497 12.528 75.747C12.8051 79.4456 15.8111 82.4516 21.8229 88.4634C24.4349 91.0754 25.7409 92.3814 26.4892 94.0127C26.5932 94.2393 26.6886 94.4696 26.7753 94.7033C27.3996 96.3859 27.3996 98.2329 27.3996 101.927V102.608C27.3996 112.033 27.3996 116.745 30.3274 119.673C33.2552 122.6 37.9674 122.6 47.3918 122.6H48.0732Z"
                        stroke="#404040" stroke-width="2.5" />
                    <path d="M93.75 56.25L56.25 93.75" stroke="#404040" stroke-width="2.5" stroke-linecap="round"
                        stroke-linejoin="round" />
                    <path d="M93.75 93.75H93.6828M56.3172 56.25H56.25" stroke="#404040" stroke-width="2.5"
                        stroke-linecap="round" stroke-linejoin="round" />
                </svg>

            </span>
            <h3 class="offers-offcanvas-empty-title">{{ _('Offers box is empty') }}</h3>
            <p class="offers-offcanvas-empty-text">{{ _('No new offers available') }}</p>
            <a href="/products/" class="offers-offcanvas-empty-btn">{{ _('Shop now') }}</a>
        </div>
        {% endif %}
    </div>
</div>

<script>
    (function () {
        var offcanvas = document.getElementById('offers-offcanvas');
        if (!offcanvas) return;

        function openOffcanvas() {
            offcanvas.classList.add('is-open');
            offcanvas.setAttribute('aria-hidden', 'false');
            document.body.style.overflow = 'hidden';
        }
        function closeOffcanvas() {
            offcanvas.classList.remove('is-open');
            offcanvas.setAttribute('aria-hidden', 'true');
            document.body.style.overflow = '';
        }

        document.addEventListener('click', function (e) {
            if (e.target.closest('[data-open-offers-offcanvas]')) {
                e.preventDefault();
                openOffcanvas();
            }
            if (e.target.closest('[data-close-offers-offcanvas]')) closeOffcanvas();
        });
        document.addEventListener('keydown', function (e) {
            if (e.key === 'Escape' && offcanvas.classList.contains('is-open')) closeOffcanvas();
        });
    })();
</script>