{% set offers_list = safeget(settings, 'offers_most_searched_categories', []) or safeget(safeget(settings, 'offers', {}), 'most_searched_categories', []) %}
<div class="search-header header-theme-bg-primary header-theme-text-for-primary-bg d-none d-lg-block">
    <div class="container-fluid">
        <div class="d-flex align-items-center search-header-bar">

            {% if settings.custom_link_text %}
            <div class="header-custom-link-area d-flex align-items-center search-header-text">
                <button type="button"
                    class="header-custom-link header-offers-trigger d-flex align-items-center header-theme-text-for-primary-bg"
